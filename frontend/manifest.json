      "icons": [
        {
          "src": "/assets/images/logo-96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "View Map",
      "short_name": "Map",
      "description": "Explore vendors on the map",
      "url": "/pages/customer/map.html",
      "icons": [
        {
          "src": "/assets/images/logo-96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "My Suggestions",
      "short_name": "Suggestions",
